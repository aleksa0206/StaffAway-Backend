{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",                    // ← Promeni u ES2022
    "moduleResolution": "bundler",         // ← Ostavi bundler
    "rootDir": "./src",
    "outDir": "./dist/out-tsc",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  }
}